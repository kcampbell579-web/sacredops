// SacredOps — construction operations platform
// Prisma schema covering Staffing, Certifications & Training,
// Safety & Incidents, and Permits & Documents.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Portal persistence
// ---------------------------------------------------------------------------
// The Supervisor Portal stores its working data as JSON documents keyed by
// name (all keys are prefixed "sacredops_"). AppState is the durable,
// cross-device backing store that the client syncs localStorage against.

model AppState {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

// Form submissions (permits, checklists, orientations, JHAs) created in the
// Worker Portal and reviewed in the Supervisor Portal. This is the first
// "decomposed" store: the portals still read/write the `sacredops_submissions`
// localStorage key, but the server projects that JSON array into these typed,
// queryable rows (see lib/projectors.ts) instead of an opaque AppState blob.
model Submission {
  id        String   @id // client-generated id (e.g. "w1720...", "seed1")
  project   String
  formTitle String
  worker    String?
  date      String? // human-facing date string as captured in the form
  spec      Json? // full form body (meta, sections, signatures)
  createdAt DateTime @default(now())

  @@index([project])
  @@index([formTitle])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Trade {
  LABORER
  CARPENTER
  ELECTRICIAN
  PLUMBER
  IRONWORKER
  OPERATOR
  MASON
  WELDER
  PAINTER
  ROOFER
  HVAC
  FOREMAN
  SUPERINTENDENT
}

enum WorkerStatus {
  ACTIVE
  ON_LEAVE
  INACTIVE
}

enum JobsiteStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
}

enum AssignmentStatus {
  SCHEDULED
  ACTIVE
  COMPLETED
  CANCELLED
}

enum CertificationStatus {
  VALID
  EXPIRING_SOON
  EXPIRED
}

enum EnrollmentStatus {
  ENROLLED
  IN_PROGRESS
  COMPLETED
  FAILED
}

enum IncidentSeverity {
  NEAR_MISS
  MINOR
  SERIOUS
  CRITICAL
  FATALITY
}

enum IncidentStatus {
  REPORTED
  INVESTIGATING
  RESOLVED
  CLOSED
}

enum PermitStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  EXPIRED
}

enum DocumentCategory {
  DRAWING
  CONTRACT
  SAFETY_PLAN
  RFI
  SUBMITTAL
  PHOTO
  OTHER
}

// ---------------------------------------------------------------------------
// Organizations: unions & training providers
// ---------------------------------------------------------------------------

model Union {
  id        String   @id @default(cuid())
  name      String
  local     String? // e.g. "Local 3"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workers Worker[]
}

// ---------------------------------------------------------------------------
// Staffing & Workers
// ---------------------------------------------------------------------------

model Worker {
  id         String       @id @default(cuid())
  firstName  String
  lastName   String
  email      String?      @unique
  phone      String?
  trade      Trade
  status     WorkerStatus @default(ACTIVE)
  hireDate   DateTime     @default(now())
  hourlyRate Decimal?     @db.Decimal(10, 2)
  notes      String?

  unionId String?
  union   Union?  @relation(fields: [unionId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignments    Assignment[]
  certifications Certification[]
  enrollments    Enrollment[]
  reportedIncidents Incident[]  @relation("ReportedBy")

  @@index([trade])
  @@index([status])
}

model Jobsite {
  id        String        @id @default(cuid())
  name      String
  code      String        @unique // internal project code
  address   String?
  city      String?
  state     String?
  status    JobsiteStatus @default(ACTIVE)
  startDate DateTime?
  endDate   DateTime?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  assignments Assignment[]
  incidents   Incident[]
  permits     Permit[]
  documents   Document[]

  @@index([status])
}

model Assignment {
  id        String           @id @default(cuid())
  workerId  String
  worker    Worker           @relation(fields: [workerId], references: [id], onDelete: Cascade)
  jobsiteId String
  jobsite   Jobsite          @relation(fields: [jobsiteId], references: [id], onDelete: Cascade)
  role      String? // role on this jobsite
  status    AssignmentStatus @default(SCHEDULED)
  startDate DateTime
  endDate   DateTime?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([workerId])
  @@index([jobsiteId])
  @@index([status])
}

// ---------------------------------------------------------------------------
// Certifications & Training
// ---------------------------------------------------------------------------

model Certification {
  id           String    @id @default(cuid())
  workerId     String
  worker       Worker    @relation(fields: [workerId], references: [id], onDelete: Cascade)
  name         String // e.g. "OSHA 30", "Confined Space Entry"
  issuingBody  String?
  credentialId String?
  issuedDate   DateTime
  expiresDate  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([workerId])
  @@index([expiresDate])
}

model TrainingCourse {
  id            String   @id @default(cuid())
  title         String
  provider      String?
  description   String?
  durationHours Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  enrollments Enrollment[]
}

model Enrollment {
  id          String           @id @default(cuid())
  workerId    String
  worker      Worker           @relation(fields: [workerId], references: [id], onDelete: Cascade)
  courseId    String
  course      TrainingCourse   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  status      EnrollmentStatus @default(ENROLLED)
  enrolledAt  DateTime         @default(now())
  completedAt DateTime?
  score       Int?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([workerId, courseId])
  @@index([status])
}

// ---------------------------------------------------------------------------
// Safety & Incidents
// ---------------------------------------------------------------------------

model Incident {
  id          String           @id @default(cuid())
  jobsiteId   String
  jobsite     Jobsite          @relation(fields: [jobsiteId], references: [id], onDelete: Cascade)
  reportedById String?
  reportedBy  Worker?          @relation("ReportedBy", fields: [reportedById], references: [id], onDelete: SetNull)
  title       String
  description String
  severity    IncidentSeverity
  status      IncidentStatus   @default(REPORTED)
  occurredAt  DateTime
  location    String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([jobsiteId])
  @@index([severity])
  @@index([status])
}

// Safety inspections & walk-throughs. Decomposed store: the Supervisor Portal
// reads/writes the `sacredops_inspections` key, and the server projects that
// JSON into these rows (see lib/projectors.ts). `project` is the project name
// (custom projects don't live in the Jobsite table), status is "pass"|"open"|
// "fail", and `details` preserves the richer form body (fullSections/fullObs).
model Inspection {
  id        String   @id // client-generated id (e.g. "i1", "ni...", "wt...")
  project   String
  type      String // Scaffold, Fall Protection, Crane / Rigging, ...
  by        String? // inspector
  date      String? // human-facing date string as captured
  status    String // pass | open | fail
  note      String?
  details   Json? // extra form body (fullSections / fullObs)
  createdAt DateTime @default(now())

  items ChecklistItem[]

  @@index([project])
  @@index([status])
  @@index([type])
}

model ChecklistItem {
  id           String     @id @default(cuid())
  inspectionId String
  inspection   Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  label        String
  result       String // pass | flag
  position     Int // preserves item order within the inspection

  @@index([inspectionId])
  @@index([result])
}

// ---------------------------------------------------------------------------
// Permits & Documents
// ---------------------------------------------------------------------------

model Permit {
  id          String       @id @default(cuid())
  jobsiteId   String
  jobsite     Jobsite      @relation(fields: [jobsiteId], references: [id], onDelete: Cascade)
  type        String // e.g. "Building", "Electrical", "Excavation"
  permitNumber String?
  issuingAuthority String?
  status      PermitStatus @default(DRAFT)
  submittedAt DateTime?
  approvedAt  DateTime?
  expiresAt   DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([jobsiteId])
  @@index([status])
}

model Document {
  id          String           @id @default(cuid())
  jobsiteId   String
  jobsite     Jobsite          @relation(fields: [jobsiteId], references: [id], onDelete: Cascade)
  name        String
  category    DocumentCategory @default(OTHER)
  url         String? // link to stored file
  version     String?
  uploadedBy  String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([jobsiteId])
  @@index([category])
}
